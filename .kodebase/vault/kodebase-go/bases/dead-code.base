filters:
  or:
    - and:
        - "file.hasTag(\"symbol\")"
        - "is_dead_export == true"
    - and:
        - "file.hasTag(\"file\")"
        - "is_orphan_file == true"
views:
  - name: "Dead Code"
    order:
      - "file.name"
      - "symbol_kind"
      - "source_path"
      - "is_dead_export"
      - "is_orphan_file"
    type: "table"
